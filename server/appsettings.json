{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "Your-Super-Secret-Key-For-JWT-Token-At-Least-32-Characters-Long!",
    "Issuer": "HelloWebAPI",
    "Audience": "HelloWebClient",
    "ExpirationMinutes": 60
  },
  "Database": {
    "DbType": 1,
    "SQLite": {
      "DbPath": "app.db"
    },
    "MySQL": {
      "DbHost": "localhost",
      "DbPort": 3306,
      "DbName": "ContractManager",
      "DbUser": "root",
      "DbPassword": "your_password"
    }
  }
}
